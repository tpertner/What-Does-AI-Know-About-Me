# ============================================================
# What-Does-AI-Know-About-Me — .gitignore
# ============================================================

# Private talk materials (DO NOT COMMIT)
# The speaker deck and personal talk notes stay local only
*.pptx
*.ppt
*.key
talk/
speaker-notes*
talk-outline*

# Audit results (may contain sensitive personal information)
audit-results/
*-audit-output.*
my-audit.*
personal-*.md

# OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor and IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-workspace
*.sublime-project

# Environment and secrets
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json
credentials.json

# Node / build artifacts (in case someone adds tooling later)
node_modules/
dist/
build/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (in case someone adds tooling later)
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.orig
